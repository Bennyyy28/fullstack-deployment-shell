# Example environment variables for the Full-Stack Deployment Shell.
# Copy this file to .env.local and fill in real values for local development.
# Never commit real secrets — .env.local is gitignored, this example is not.

# NEXT_PUBLIC_ variables are exposed to the browser (bundled into client code).
# Only put non-sensitive, public values here.
NEXT_PUBLIC_APP_NAME="Full-Stack Deployment Shell"

# Variables WITHOUT the NEXT_PUBLIC_ prefix stay server-side only and are never
# sent to the browser. Use these for anything sensitive.
CONTACT_RECIPIENT_EMAIL=""
API_SECRET_KEY=""
